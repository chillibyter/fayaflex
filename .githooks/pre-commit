#!/usr/bin/env bash
# FayaFlex secret-scanning pre-commit hook.
#
# Blocks commits that introduce content matching common credential shapes
# (OAuth tokens, API keys, private keys, etc). Designed to be fast, dependency
# free, and to mirror the rules already documented in `replit.md`.
#
# Install (one line):
#   git config core.hooksPath .githooks
#
# Bypass for a single commit (use sparingly, e.g. when intentionally committing
# a sample/redacted token in docs):
#   git commit --no-verify

set -u

RED=$'\033[31m'
YELLOW=$'\033[33m'
RESET=$'\033[0m'

# Only scan files actually staged for commit. Added/Copied/Modified/Renamed.
mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACMR)

if [ ${#STAGED[@]} -eq 0 ]; then
  exit 0
fi

# Patterns are intentionally tight to keep false positives low. Each entry is
# "label|regex". Add new shapes here as they show up in real incidents.
PATTERNS=(
  "Google OAuth access token (ya29.*)|ya29\.[A-Za-z0-9_-]{20,}"
  "Google API key (AIza...)|AIza[0-9A-Za-z_-]{35}"
  "OpenAI API key (sk-...)|sk-(proj-)?[A-Za-z0-9_-]{20,}"
  "GitHub token (ghp_/gho_/ghu_/ghs_/ghr_)|gh[pousr]_[A-Za-z0-9]{30,}"
  "Slack token (xox[baprs]-)|xox[baprs]-[A-Za-z0-9-]{10,}"
  "Stripe live secret key (sk_live_)|sk_live_[A-Za-z0-9]{20,}"
  "AWS access key id|AKIA[0-9A-Z]{16}"
  "PEM private key block|-----BEGIN ([A-Z]+ )?PRIVATE KEY-----"
  "Postgres URL with embedded password|postgres(ql)?:\/\/[^[:space:]:@\"']+:[^[:space:]:@\"']+@"
)

# Files we never want to scan (binary blobs, lockfiles, the hook itself).
SKIP_REGEX='(^|/)(package-lock\.json|pnpm-lock\.yaml|yarn\.lock|\.githooks/pre-commit)$|\.(png|jpe?g|gif|webp|ico|pdf|zip|gz|tgz|mp4|mov|woff2?|ttf|otf)$'

# Allowlist: Firebase iOS client API keys are documented as safe-to-commit.
ALLOWLIST_REGEX='GoogleService-Info.*\.plist$'

# Per-rule path allowlist for documented false positives. The PEM marker
# string used to also appear as a literal in normalizeApnsKey() inside
# server/pushService.ts; that has since been split so the regex no longer
# matches. The allowlist is therefore scoped to replit.md only, which still
# has to spell the marker out in its Security Notes documentation.
PEM_ALLOWLIST_REGEX='^replit\.md$'

violations=0
report=""

for file in "${STAGED[@]}"; do
  [ -f "$file" ] || continue
  if [[ "$file" =~ $SKIP_REGEX ]]; then
    continue
  fi

  # Read only the staged blob so unstaged edits don't muddy the scan.
  content=$(git show ":$file" 2>/dev/null) || continue

  for entry in "${PATTERNS[@]}"; do
    label="${entry%%|*}"
    regex="${entry#*|}"

    matches=$(printf '%s\n' "$content" | grep -nE -e "$regex" || true)
    [ -z "$matches" ] && continue

    # Apply allowlist for Google API keys inside Firebase plist.
    if [[ "$label" == "Google API key (AIza...)" && "$file" =~ $ALLOWLIST_REGEX ]]; then
      continue
    fi

    # Apply per-rule path allowlist for the PEM marker false positive.
    if [[ "$label" == "PEM private key block" && "$file" =~ $PEM_ALLOWLIST_REGEX ]]; then
      continue
    fi

    violations=$((violations + 1))
    report+=$'\n'"${RED}✖ ${label}${RESET} in ${YELLOW}${file}${RESET}"$'\n'
    while IFS= read -r line; do
      report+="    ${line}"$'\n'
    done <<< "$matches"
  done
done

if [ $violations -gt 0 ]; then
  printf '%s\n' "${RED}Pre-commit secret scan blocked this commit.${RESET}"
  printf '%s' "$report"
  cat <<EOF

Remove the secret from the staged files (and any committed history) and rotate
the underlying credential before retrying. If this is a documented false
positive, add it to .githooks/pre-commit or run with --no-verify.
EOF
  exit 1
fi

# Backstop: high-entropy detector for credentials that don't match any known
# prefix (random session tokens, webhook signing secrets, custom-format keys).
# Operates on the diff of *staged* changes only - existing repo content has
# already been audited via the one-shot sweep documented in replit.md, so we
# only block what this commit introduces. Allowlist + threshold logic lives
# in .githooks/entropy-scan.py so the local hook and the CI job stay in sync.
if command -v python3 >/dev/null 2>&1 && [ -f .githooks/entropy-scan.py ]; then
  if ! git diff --cached -U0 --diff-filter=ACMR -- | \
       python3 .githooks/entropy-scan.py; then
    exit 1
  fi
fi

exit 0
